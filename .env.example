# Token del bot — obténlo de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Tu chat ID de Telegram (el admin). Envía /start al bot para obtenerlo.
ADMIN_CHAT_ID=123456789

# Google Gemini API Key (gratis) — https://aistudio.google.com/apikey
# Si no lo configuras, el bot usa mensajes predeterminados
GEMINI_API_KEY=your-gemini-api-key-here
